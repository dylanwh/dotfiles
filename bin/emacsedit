#!/usr/bin/perl
use strict;
use warnings;
use Env qw($INSIDE_EMACS $TERM);

my ($filename, $position);
my @new_argv;

if ($INSIDE_EMACS || !$TERM || !-t STDOUT) {
    @new_argv = ();
} else {
    @new_argv = ('-q', '-a', "", "-nw", "-c");
}

my $files = 0;

for (@ARGV) {
    if (/^-/) {
        push @new_argv, $_;
    }
    elsif (/^\+/) {
        $position = $_;
    }
    else {
        $filename = $_;
    }
    if (defined $filename && defined $position) {
        push @new_argv, $position, $filename;
        $files++;
        $filename = undef;
        $position = undef;
    }
}

if (defined $filename) {
    push @new_argv, $filename;
    $files++;
}

if ($files == 0) {
    push @new_argv, '-e', '(switch-to-buffer (generate-new-buffer "untitled"))';
}

exec "emacsclient", @new_argv
