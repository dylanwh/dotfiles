#!/bin/sh
set -euo pipefail

foreground=0

while getopts "f" opt; do
    case "$opt" in
    f) foreground=1 ;;
    *) ;;
    esac
done

if [[ -z "$COLORFGBG" ]]; then
    echo "COLORFGBG not set"
    read _foo
fi

if [[ "$foreground" -eq 1 ]]; then
    exec emacs -nw --eval '(+eshell/frame)'
else
    exec emacsclient -q -a '' -nw -e '(+eshell/frame)'
fi
